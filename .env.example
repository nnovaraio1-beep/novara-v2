# NOVARA v2 — copy to .env.local. No secrets required to run in this phase.
NEXT_PUBLIC_SITE_URL=https://nnovara.io

# ── Payments ────────────────────────────────────────────────
# (unset) → online card payment is DISABLED. Checkout offers bank transfer and
#           quotation requests instead — it never shows a card form that does
#           nothing. Set PAYMENT_PROVIDER only once a real provider is implemented.
PAYMENT_PROVIDER=            # stripe | paypal | hyperpay | tap | myfatoorah | bank_transfer
ENABLE_BANK_TRANSFER=true
TAX_RATE=0                   # decimal, e.g. 0.16 for 16% — applied server-side only

# Provider secrets — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TAP_SECRET_KEY=
TAP_WEBHOOK_SECRET=
MYFATOORAH_API_KEY=
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID=

# Webhook endpoints (point each provider dashboard here):
#   https://nnovara.io/api/payments/webhook/stripe   (etc.)
# An order is marked paid ONLY from a verified webhook — never a browser redirect.

# ── Accounts (optional; browsing + guest checkout work without these) ──
AUTH_SECRET=                 # openssl rand -base64 32
DATABASE_URL=
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=

# ── Email (contact form, order confirmations) ──
SMTP_URL=
MAIL_FROM=hello@nnovara.io

# ── Admin dashboard (§34) ───────────────────────────────────
# PostgreSQL is required for the admin area. The public site runs without it.
DATABASE_URL=                # postgresql://user:pass@host:5432/novara

# First-run super admin — used once by `npm run admin:setup`, then rotate.
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=      # min 12 chars; you'll be forced to change it on first login
ADMIN_INITIAL_NAME=Super Admin

# Media storage (§8) — local in dev; set a provider for production.
MEDIA_PROVIDER=local         # local | s3 | r2 | cloudinary | vercel_blob
# S3_BUCKET= S3_REGION= S3_ACCESS_KEY_ID= S3_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID= R2_BUCKET= R2_ACCESS_KEY_ID= R2_SECRET_ACCESS_KEY=
# CLOUDINARY_URL=
# BLOB_READ_WRITE_TOKEN=
