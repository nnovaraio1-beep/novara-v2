// NOVARA admin — database schema (§30).
// PostgreSQL + Prisma. Run: npx prisma migrate dev  (see README "Admin setup").
// This schema is the SINGLE SOURCE OF TRUTH for admin-managed content — never
// localStorage (§30). Public pages read published rows through the data layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── AUTH & RBAC (§2, §20) ───────────────────────────

enum AdminRole {
  super_admin
  admin
  content_manager
  store_manager
  support_agent
  viewer
}

model AdminUser {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  passwordHash      String
  role              AdminRole @default(viewer)
  isActive          Boolean   @default(true)
  mustChangePassword Boolean  @default(false)
  twoFactorSecret   String?   // reserved for optional TOTP (§2)
  twoFactorEnabled  Boolean   @default(false)
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions          Session[]
  auditLogs         AuditLog[]
  revisions         Revision[]

  @@index([email])
  @@index([role])
}

// Granular permissions (§20) — a permission grant is role-independent so we can
// override per user. Role → default permission set lives in code (rbac.ts);
// these rows are explicit grants/revokes layered on top.
model PermissionGrant {
  id         String  @id @default(cuid())
  userId     String
  permission String  // e.g. "content.write", "orders.read"
  granted    Boolean @default(true)
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique // we store a hash of the session token, never the token
  csrfToken    String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────── CONTENT (§4, §5, §26) ───────────────────────────

enum PublishStatus {
  draft
  published
  scheduled
  archived
}

model Page {
  id          String        @id @default(cuid())
  slug        String        @unique
  titleEn     String
  titleAr     String
  status      PublishStatus @default(draft)
  publishAt   DateTime?
  seoId       String?
  deletedAt   DateTime?     // soft delete / trash (§28)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sections    PageSection[]

  @@index([status])
  @@index([slug])
}

model PageSection {
  id        String   @id @default(cuid())
  pageId    String
  type      String   // hero | text | image | serviceGrid | ... (validated allowlist)
  order     Int      @default(0)
  hidden    Boolean  @default(false)
  // settings are validated JSON (content/layout/visibility/design/motion §5),
  // never raw HTML except the super_admin-only customHtml block, sanitized server-side.
  settings  Json
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
}

// Version history for pages/sections/services/packages/posts/legal/theme (§26).
model Revision {
  id          String   @id @default(cuid())
  entityType  String   // "page" | "service" | "package" | "post" | "legal" | "theme"
  entityId    String
  snapshot    Json     // full before-state
  editedById  String?
  editedBy    AdminUser? @relation(fields: [editedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}

// ─────────────────────────── THEME & ANIMATION (§6, §7) ───────────────────────────

model ThemeSettings {
  id        String   @id @default(cuid())
  name      String   @default("NOVARA Default")
  isActive  Boolean  @default(false)
  tokens    Json     // validated design tokens → CSS variables (§6)
  updatedAt DateTime @updatedAt
}

model AnimationSettings {
  id        String   @id @default(cuid())
  isActive  Boolean  @default(true)
  settings  Json     // enable flags, durations, easings — validated ranges (§7)
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── MEDIA (§8) ───────────────────────────

model MediaAsset {
  id          String   @id @default(cuid())
  filename    String
  storageKey  String   // path/key in the storage provider — NOT base64 (§8)
  provider    String   @default("local") // local | s3 | r2 | cloudinary | vercel_blob
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  altEn       String?
  altAr       String?
  captionEn   String?
  captionAr   String?
  focalX      Float?
  focalY      Float?
  folder      String?
  checksum    String?  // duplicate detection (§8)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([folder])
  @@index([checksum])
}

// ─────────────────────────── STORE / CATALOG (§9, §10, §11) ───────────────────────────

model Service {
  id            String        @id @default(cuid())
  slug          String        @unique
  categoryKey   String?
  titleEn       String
  titleAr       String
  descriptionEn String        @db.Text
  descriptionAr String        @db.Text
  valueEn       String?
  valueAr       String?
  priceFils     Int?          // null = request quote
  billingType   String        @default("once")
  timelineEn    String?
  timelineAr    String?
  imageId       String?
  featuresEn    Json?
  featuresAr    Json?
  featured      Boolean       @default(false)
  purchasable   Boolean       @default(true)
  status        PublishStatus @default(draft)
  order         Int           @default(0)
  seo           Json?
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([categoryKey])
}

model Package {
  id            String        @id @default(cuid())
  slug          String        @unique
  categoryKey   String
  titleEn       String
  titleAr       String
  descriptionEn String        @db.Text
  descriptionAr String        @db.Text
  priceFils     Int?
  salePriceFils Int?
  currency      String        @default("JOD")
  billingType   String        @default("once")
  timelineEn    String?
  timelineAr    String?
  featuresEn    Json?
  featuresAr    Json?
  platforms     Int?
  posts         Int?
  stories       Int?
  reels         Int?
  aiVideos      Int?
  popular       Boolean       @default(false)
  featured      Boolean       @default(false)
  quoteOnly     Boolean       @default(false)
  addToCart     Boolean       @default(true)
  buyNow        Boolean       @default(true)
  status        PublishStatus @default(draft)
  order         Int           @default(0)
  seo           Json?
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([categoryKey])
}

model Category {
  key         String   @id
  titleEn     String
  titleAr     String
  introEn     String?
  introAr     String?
  group       String   @default("onetime")
  imageId     String?
  order       Int      @default(0)
  visible     Boolean  @default(true)
}

model AddOn {
  id           String   @id @default(cuid())
  slug         String   @unique
  titleEn      String
  titleAr      String
  priceFils    Int
  currency     String   @default("JOD")
  billingType  String   @default("once")
  maxQuantity  Int      @default(1)
  active       Boolean  @default(true)
  order        Int      @default(0)
}

// ─────────────────────────── PORTFOLIO & BLOG (§12, §13) ───────────────────────────

model PortfolioProject {
  id           String        @id @default(cuid())
  slug         String        @unique
  titleEn      String
  titleAr      String
  clientName   String?
  isConcept    Boolean       @default(true) // renders "Concept Project"/"مشروع تصوّري"
  category     String?
  coverImageId String?
  summaryEn    String?
  summaryAr    String?
  challengeEn  String?       @db.Text
  challengeAr  String?       @db.Text
  solutionEn   String?       @db.Text
  solutionAr   String?       @db.Text
  year         Int?
  featured     Boolean       @default(false)
  status       PublishStatus @default(draft)
  seo          Json?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
}

model BlogPost {
  id           String        @id @default(cuid())
  slug         String        @unique
  titleEn      String
  titleAr      String
  excerptEn    String?
  excerptAr    String?
  bodyEn       String        @db.Text // sanitized HTML (§13)
  bodyAr       String        @db.Text
  coverImageId String?
  author       String?
  category     String?
  tags         Json?
  publishAt    DateTime?
  status       PublishStatus @default(draft)
  seo          Json?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
}

// ─────────────────────────── NAV, TRANSLATIONS, SETTINGS (§14, §15, §24) ───────────────────────────

model NavigationMenu {
  id    String           @id @default(cuid())
  key   String           @unique // "header" | "mobile" | "footer_company" | ...
  items NavigationItem[]
}

model NavigationItem {
  id         String  @id @default(cuid())
  menuId     String
  labelEn    String
  labelAr    String
  href       String
  external   Boolean @default(false)
  newTab     Boolean @default(false)
  order      Int     @default(0)
  hideLocale String? // "en" | "ar" | null
  parentId   String?
  menu       NavigationMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId, order])
}

model TranslationEntry {
  id        String   @id @default(cuid())
  namespace String
  key       String
  valueEn   String   @db.Text
  valueAr   String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([namespace, key])
  @@index([namespace])
}

model SiteSettings {
  id        String   @id @default("singleton")
  data      Json     // site name, contact, socials, analytics IDs, maintenance (§24)
  updatedAt DateTime @updatedAt
}

model LegalDocument {
  id        String        @id @default(cuid())
  key       String        @unique // privacy | terms | refund | cancellation | delivery | subscription | cookies
  titleEn   String
  titleAr   String
  bodyEn    String        @db.Text
  bodyAr    String        @db.Text
  status    PublishStatus @default(draft)
  updatedAt DateTime      @updatedAt
}

// ─────────────────────────── FORMS & COMMERCE (§17, §18, §19, §22) ───────────────────────────

model FormSubmission {
  id         String   @id @default(cuid())
  type       String   // contact | project | quote | support | newsletter
  data       Json
  isRead     Boolean  @default(false)
  isReplied  Boolean  @default(false)
  isSpam     Boolean  @default(false)
  assignedTo String?
  notes      String?  @db.Text
  deletedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([isRead])
}

model Customer {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  phone       String?
  company     String?
  taxNumber   String?
  locale       String   @default("en")
  status       String   @default("active")
  tags         Json?
  notes        String?  @db.Text
  passwordHash String?
  createdAt    DateTime @default(now())
  orders       Order[]
  quotations   Quotation[]
  sessions     CustomerSession[]

  @@index([email])
}

// جلسات دخول العملاء (منفصلة عن جلسات الأدمن للأمان).
model CustomerSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  csrfToken  String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?

  @@index([customerId])
  @@index([expiresAt])
}

enum OrderStatus {
  draft
  pending_payment
  confirmed
  in_review
  in_progress
  completed
  cancelled
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerId    String?
  email         String
  status        OrderStatus @default(draft)
  subtotalFils  Int
  discountFils  Int         @default(0)
  taxFils       Int         @default(0)
  totalFils     Int
  currency      String      @default("JOD")
  couponCode    String?
  customerNote  String?     @db.Text
  internalNote  String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  payments      Payment[]
  invoice       Invoice?
  customer      Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([orderNumber])
}

// Snapshot at time of order — immune to later price changes (§12/§18).
model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  productSlug  String
  productName  String
  kind         String // package | service
  unitFils     Int
  billingType  String
  quantity     Int    @default(1)
  addons       Json   // [{slug,name,priceFils}]
  discountFils Int    @default(0)
  taxFils      Int    @default(0)
  lineFils     Int
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Quotation {
  id          String   @id @default(cuid())
  number      String   @unique
  customerId  String?
  status      String   @default("open") // open | sent | accepted | rejected | expired
  lineItems   Json     // custom line items with prices
  discountFils Int     @default(0)
  taxFils     Int      @default(0)
  totalFils   Int      @default(0)
  currency    String   @default("JOD")
  notes       String?  @db.Text
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
}

model Payment {
  id          String   @id @default(cuid())
  orderId     String
  provider    String
  sessionId   String
  status      String   @default("pending")
  amountFils  Int
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, sessionId])
  @@index([orderId])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  orderId       String   @unique
  totalFils     Int
  currency      String   @default("JOD")
  paymentStatus String   @default("pending")
  issuedAt      DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Coupon {
  code            String   @id
  percentOff      Int?
  amountOffFils   Int?
  expiresAt       DateTime?
  maxRedemptions  Int?
  timesRedeemed   Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model PaymentProviderConfig {
  id           String   @id @default(cuid())
  provider     String   @unique // stripe | paypal | hyperpay | tap | myfatoorah | bank_transfer
  displayName  String
  enabled      Boolean  @default(false)
  mode         String   @default("test") // test | live
  currency     String   @default("JOD")
  publicId     String?  // publishable key / merchant id — safe to show
  // NOTE: secret keys are NEVER stored here. They live in server env vars only (§21).
  instructions String?  @db.Text // bank transfer instructions
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────── AUDIT & BACKUP (§25, §27) ───────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorEmail  String?
  action      String   // login | update | delete | publish | role_change | ...
  entityType  String?
  entityId    String?
  ipAddress   String?
  userAgent   String?
  before      Json?    // secrets scrubbed before write (§25)
  after       Json?
  createdAt   DateTime @default(now())
  actor       AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model BackupRecord {
  id          String   @id @default(cuid())
  createdById String?
  storageKey  String
  sizeBytes   Int?
  kind        String   @default("full") // full | content | translations | settings
  createdAt   DateTime @default(now())
}
